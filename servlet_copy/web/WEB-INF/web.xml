<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

<!--应用域中放用户共享的数据和少量的和基本不变的-->
    <context-param>
        <param-name>test1</param-name>
        <param-value>100</param-value>
    </context-param>
    <context-param>
        <param-name>test2</param-name>
        <param-value>200</param-value>
    </context-param>


    <servlet>
        <servlet-name>vip</servlet-name>
        <servlet-class>com.myservlet.myserver.vipServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>vip</servlet-name>
        <url-pattern>/vip</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>httpmy</servlet-name>
        <servlet-class>com.myservlet.myserver.httpServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>httpmy</servlet-name>
        <url-pattern>/httpp</url-pattern>
    </servlet-mapping>


</web-app>