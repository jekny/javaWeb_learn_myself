<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <servlet>
        <servlet-name>list</servlet-name>
        <servlet-class>com.oa.myItem02.deptServer.listServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>list</servlet-name>
        <url-pattern>/dept/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>detail</servlet-name>
        <servlet-class>com.oa.myItem02.deptServer.detailServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>detail</servlet-name>
        <url-pattern>/dept/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>delete</servlet-name>
        <servlet-class>com.oa.myItem02.deptServer.deleteServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>delete</servlet-name>
        <url-pattern>/dept/delete</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>add</servlet-name>
        <servlet-class>com.oa.myItem02.deptServer.addServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>add</servlet-name>
        <url-pattern>/dept/add</url-pattern>
    </servlet-mapping>

    <!--    这里是修改页面类，展示你要修改的数据，点击提交才执行真正的修改（即下面的那个类）-->
    <servlet>
        <servlet-name>edit</servlet-name>
        <servlet-class>com.oa.myItem02.deptServer.editServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>edit</servlet-name>
        <url-pattern>/dept/edit</url-pattern>
    </servlet-mapping>

    <!--    真正修改的逻辑类-->
    <servlet>
        <servlet-name>xiugai</servlet-name>
        <servlet-class>com.oa.myItem02.deptServer.xiugaiServer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>xiugai</servlet-name>
        <url-pattern>/dept/xiugai</url-pattern>
    </servlet-mapping>
</web-app>